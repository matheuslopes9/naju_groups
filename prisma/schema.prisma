generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Cada "workspace" = 1 nicho = 1 número WhatsApp + N grupos.
// Varredura é GLOBAL (catalog-worker a cada 6h). Workspace só decide o que
// recebe via keywords + faixa de preço + desconto mínimo.
model Workspace {
  id           String   @id @default(cuid())
  name         String
  niche        String?
  description  String?
  // Filtros de oferta
  minDiscount  Int      @default(20) @map("min_discount")
  onlyFreeShipping Boolean @default(true) @map("only_free_shipping")
  onlyDeals    Boolean  @default(true) @map("only_deals")
  keywords     String?
  priceMin     Float?   @map("price_min")
  priceMax     Float?   @map("price_max")
  cooldownDays Int      @default(30) @map("cooldown_days")
  // Nicho principal (decide o TOM da copy — hooks/closers de copy.js)
  nichePreset  String? @map("niche_preset") // ex: 'beauty-f', 'tech', 'fitness-m'
  // Nichos extras (CSV) — só agregam keywords, NÃO afetam o tom da copy.
  // Permite workspace híbrido (ex: Beauty-F + Fashion-F + Babies) mantendo
  // mensagens consistentes no tom feminino-beauty.
  extraNiches  String? @map("extra_niches")
  audience     String? // 'female', 'male', 'unisex' (derivado do nicho principal)
  adStyle      String  @default("compact") @map("ad_style") // 'compact' ou 'rich'
  typingSimulation Boolean @default(true) @map("typing_simulation")
  // Auto-aprovação (agente IA)
  autoApproveEnabled   Boolean @default(false) @map("auto_approve_enabled")
  autoApproveThreshold Int     @default(80) @map("auto_approve_threshold")
  autoApproveMaxDaily  Int     @default(10) @map("auto_approve_max_daily")
  // Janela de envio diário (formato "HH:MM-HH:MM", default 08:00-22:00)
  sendWindowStart      String  @default("08:00") @map("send_window_start")
  sendWindowEnd        String  @default("22:00") @map("send_window_end")
  // Intervalo entre envios da fila (minutos)
  queueIntervalMin     Int     @default(5) @map("queue_interval_min")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  whatsappSession WhatsappSession?
  groups          Group[]
  offers          Offer[]
  queuedSends     QueuedSend[]

  @@map("workspaces")
}

// Snapshot global de TUDO que o catalog-worker scaneou.
// Diferente de Offer (que é por workspace, já filtrada), ScrapedOffer guarda
// a oferta raw uma única vez. Permite:
//   - reprocessar com filtros novos sem revarrer o ML
//   - estatísticas globais do funil (147 scaneadas → quantas em cada filtro)
//   - dedup ao varrer (não salva 2× o mesmo MLB)
model ScrapedOffer {
  id            String   @id @default(cuid())
  productId     String   @unique @map("product_id")
  title         String
  price         Float
  originalPrice Float?   @map("original_price")
  discountPercent Int    @default(0) @map("discount_percent")
  currency      String   @default("BRL")
  permalink     String
  imageUrl      String   @map("image_url")
  freeShipping  Boolean  @default(false) @map("free_shipping")
  soldQuantity  Int      @default(0) @map("sold_quantity")
  coupon        String?
  highlight     String?
  categoryDetected String? @map("category_detected")
  commissionPct Float?   @map("commission_pct")
  estimatedCommission Float? @map("estimated_commission")
  sourceId      String?  @map("source_id") // qual fonte do catálogo trouxe
  lastSeenAt    DateTime @default(now()) @map("last_seen_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([lastSeenAt])
  @@index([sourceId])
  @@map("scraped_offers")
}

// Fila de envio: ofertas auto-aprovadas que aguardam o slot agendado.
// Sender daemon checa a cada 30s e dispara quando scheduledFor <= now
// E hora atual está dentro da janela do workspace.
model QueuedSend {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  offerId       String   @map("offer_id")
  scheduledFor  DateTime @map("scheduled_for")
  status        String   @default("queued") // queued | sending | sent | failed | cancelled
  sentAt        DateTime? @map("sent_at")
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, offerId])
  @@index([status, scheduledFor])
  @@index([workspaceId, status, scheduledFor])
  @@map("queued_sends")
}

model WhatsappSession {
  id          String   @id @default(cuid())
  workspaceId String   @unique @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phoneNumber String?  @map("phone_number")
  status      String   @default("disconnected") // disconnected, qr, connecting, connected
  lastQrAt    DateTime? @map("last_qr_at")
  connectedAt DateTime? @map("connected_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_sessions")
}

// Grupos de WhatsApp em cada workspace.
// type: "staging" (revisão sua) ou "publish" (público — informativo, posts são manuais)
model Group {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  jid         String   // formato: 123@g.us
  name        String
  type        String   @default("staging") // staging | publish
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, jid])
  @@map("groups")
}

// Ofertas processadas (busca + filtro). Status define posição no funil.
model Offer {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productId     String   @map("product_id")
  title         String
  price         Float
  originalPrice Float?   @map("original_price")
  discountPercent Int    @default(0) @map("discount_percent")
  currency      String   @default("BRL")
  permalink     String
  affiliateUrl  String   @map("affiliate_url")
  imageUrl      String   @map("image_url")
  freeShipping  Boolean  @default(false) @map("free_shipping")
  condition     String?
  soldQuantity  Int      @default(0) @map("sold_quantity")
  // Enriquecimento
  coupon        String?  // texto do cupom (ex: "Cupom 10% OFF")
  highlight     String?  // selo (ex: "Oferta do Dia", "Mais Vendido")
  categoryDetected String? @map("category_detected") // 'beauty', 'fashion', etc
  commissionPct Float?   @map("commission_pct")   // 0.16 = 16%
  estimatedCommission Float? @map("estimated_commission") // price * commissionPct
  score         Int?     // 0-100, atratividade
  // Shortlink oficial gerado no portal afiliados (preferido sobre ?tag=)
  shortlink         String?
  shortlinkAddedAt  DateTime? @map("shortlink_added_at")
  // Status
  status        String   @default("pending")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, productId])
  @@index([workspaceId, status])
  @@index([productId, workspaceId, createdAt])
  @@map("offers")
}

// Token OAuth do Mercado Livre. Único por conta (você).
model MlToken {
  id           Int      @id @default(1)
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  obtainedAt   DateTime @map("obtained_at")
  expiresIn    Int      @map("expires_in")
  userId       String?  @map("user_id")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ml_tokens")
}

// Config do App ML Developers (Client ID + Secret encriptado + Redirect URI + tag)
// Singleton (id=1). Permite gerenciar pelo dashboard ao invés do .env.
model MlAppConfig {
  id              Int      @id @default(1)
  clientId        String   @map("client_id")
  clientSecretEnc String   @map("client_secret_enc") // AES-256-GCM, base64
  redirectUri     String   @map("redirect_uri")
  affiliateTag    String?  @map("affiliate_tag")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("ml_app_config")
}

// Sessão de auth do dashboard (cookie token → user)
model AuthSession {
  token     String   @id
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("auth_sessions")
}

// Sessão headless do Playwright pro portal de afiliados ML.
// Singleton (id=1). Cookies criptografados.
model AffiliateSession {
  id          Int       @id @default(1)
  cookiesEnc  String?   @map("cookies_enc") // AES-256-GCM JSON dos cookies do Playwright
  status      String    @default("disconnected") // disconnected | connected | checking | error
  lastCheckAt DateTime? @map("last_check_at")
  lastError   String?   @map("last_error")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("affiliate_sessions")
}

// Log do agente IA — decisões automáticas
model AgentAction {
  id          String   @id @default(cuid())
  workspaceId String?  @map("workspace_id")
  offerId     String?  @map("offer_id")
  action      String   // approve | reject | skip | error
  reason      String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([createdAt])
  @@map("agent_actions")
}

// Log de ações importantes (auditoria)
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // 'login', 'logout', 'workspace.create', 'offer.approve', etc
  entity      String?  // workspace | offer | group | ml | wa
  entityId    String?  @map("entity_id")
  workspaceId String?  @map("workspace_id")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}
