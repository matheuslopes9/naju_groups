# ===== Servidor =====
PORT=3000
NODE_ENV=production

# ===== Postgres (EasyPanel cria a string com o app de Postgres) =====
DATABASE_URL=postgresql://USER:PASS@HOST:5432/naju?schema=public

# ===== Auth do dashboard (senha única) =====
DASHBOARD_PASSWORD=troque-isto-por-uma-senha-forte

# ===== Criptografia de segredos no DB =====
# Chave AES-256-GCM (32 bytes em base64). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Se não setar, o sistema deriva da DASHBOARD_PASSWORD (pragmático mas
# significa que trocar DASHBOARD_PASSWORD invalida os segredos salvos).
APP_ENCRYPTION_KEY=

# ===== Mercado Livre — OPCIONAL (preferir cadastrar pelo dashboard) =====
# Vá em Configurações no dashboard para preencher Client ID/Secret/Redirect
# de forma segura. As variáveis abaixo são só fallback pra primeiro deploy.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://najubeautyclub.azespo.com.br/ml/callback
ML_AFFILIATE_TAG=najubeautyclub
