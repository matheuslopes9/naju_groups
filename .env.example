# ===== Servidor =====
PORT=3000

# ===== Mercado Livre App (developers.mercadolivre.com.br) =====
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Use a URL pública do seu deploy + /ml/callback
# Local: http://localhost:3000/ml/callback
# Prod:  https://seubot.easypanel.host/ml/callback
ML_REDIRECT_URI=http://localhost:3000/ml/callback

# ===== Tag de afiliado =====
# Sua tag (Etiqueta em uso) do portal de afiliados.
# Formato simples (legado): SEUNOME
# Formato matt (novo):      matt:USERNAME:TOOLID
ML_AFFILIATE_TAG=najubeautyclub

# ===== WhatsApp =====
# JID do grupo de staging (só você). Rode `npm run wa:list-groups`
WA_STAGING_GROUP_JID=

# ===== Filtros de busca =====
SEARCH_QUERY=
CATEGORY_IDS=
MIN_DISCOUNT_PERCENT=20
ONLY_FREE_SHIPPING=true
ONLY_DEALS=true
MAX_POSTS_PER_RUN=3
