# ===== Servidor =====
PORT=3000
NODE_ENV=production

# ===== Postgres (EasyPanel cria a string com o app de Postgres) =====
DATABASE_URL=postgresql://USER:PASS@HOST:5432/naju?schema=public

# ===== Auth do dashboard (senha única) =====
DASHBOARD_PASSWORD=troque-isto-por-uma-senha-forte

# ===== Mercado Livre App (developers.mercadolivre.com.br) =====
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://najubeautyclub.azespo.com.br/ml/callback

# ===== Tag de afiliado =====
# Pegue em afiliados.mercadolivre.com.br ("Etiqueta em uso")
# Formato simples: SEUNOME
# Formato matt:    matt:USERNAME:TOOLID
ML_AFFILIATE_TAG=najubeautyclub
